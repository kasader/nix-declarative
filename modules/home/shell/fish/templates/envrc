#!/bin/bash

# direnv loads the Nix flake in this directory, equivalent to `nix develop`
# but applied automatically on `cd`. https://direnv.net/
use flake

# Local dev secrets: copy .env.example -> .env and fill in values.
# .env is the gitignored cache; never commit it. dotenv_if_exists is a no-op
# when the file is absent, and re-loads direnv whenever the file changes.
dotenv_if_exists .env
