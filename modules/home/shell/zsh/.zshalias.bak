alias k='kubectl'
alias kctx='kubectx'
alias kns='kubens'

alias mr='mise run'
alias glci='golangci-lint run ./...'

alias gcnv='git commit --no-verify -m'

alias gclist='gcloud config configurations list'
alias gcact='gcloud config configuration activate'

alias e=$EDITOR
alias c='clear'

